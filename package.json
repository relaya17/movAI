{
  "name": "movai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "start:web": "pnpm --filter @movai/web start",
    "build:web": "turbo run build --filter @movai/web",
    "predev": "node scripts/kill-dev-ports.mjs",
    "dev": "turbo run dev",
    "dev:clean": "node scripts/kill-dev-ports.mjs && node -e \"require('node:fs').rmSync('apps/web/.next',{recursive:true,force:true})\" && turbo run dev",
    "dev:worker": "pnpm --filter @movai/api dev:worker",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@movai/config": "workspace:*",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  },
  "type": "module",
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1"
  }
}
