# --- Database (packages/db) ---
# Local docker-compose maps Postgres to host port 5433 (5432 is often taken by other projects).
# Use the *pooled* connection string (PgBouncer) for DATABASE_URL at runtime.
# Use the *direct* connection string for DATABASE_URL_DIRECT (drizzle-kit migrations).
DATABASE_URL=postgres://movai:movai@localhost:5433/movai
DATABASE_URL_DIRECT=postgres://movai:movai@localhost:5433/movai
# Postgres connections *per process* (apps/api's HTTP process and worker
# process each open their own pool of this size). 10 is a safe local-dev
# default; raise it for production based on your Postgres plan's own
# connection ceiling (see apps/api/src/infra/infra.module.ts).
DATABASE_POOL_MAX=10

# --- Redis (packages/cache, packages/queue) ---
REDIS_URL=redis://127.0.0.1:6380

# --- Meilisearch (packages/search) ---
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=movai-dev-master-key

# --- Auth.js (apps/web) ---
# Generate with: npx auth secret
AUTH_SECRET=
# Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web application).
# Authorized redirect URI: http://localhost:3100/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Content sources (packages/content-adapters) ---
YOUTUBE_API_KEY=
# https://www.themoviedb.org/settings/api - free, used only for metadata
# enrichment (poster/genres/synopsis/tmdbId), never for streaming itself.
# Without this set, ingested movies are stored with whatever thin metadata
# the source adapter (Archive.org/YouTube) provided and worker.ts logs a
# warning on boot - ingestion still works, just with no posters/genres.
TMDB_API_KEY=

# --- Studio uploads (apps/web/lib/media-storage.ts) ---
# Cloudinary dashboard > Settings > Access Keys. The API secret must never
# be exposed to the client - it's only used server-side to sign a one-time
# upload authorization, which is what the browser actually sends the file
# with (see lib/upload-actions.ts). Without these three set, uploads in the
# Studio will fail with a clear "upload storage not configured" error
# instead of silently doing nothing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI Studio generation (apps/web/lib/replicate.ts) ---
# https://replicate.com/account/api-tokens - Replicate hosts the actual
# video/music/voice generation models, billed per-second of compute. Without
# this set, the Studio's generate buttons will fail with a clear
# "AI generation is not configured" error instead of silently faking it.
REPLICATE_API_TOKEN=
# Optional overrides if you want to swap the underlying model later without
# a code change - defaults match what lib/replicate.ts uses when unset.
REPLICATE_VIDEO_MODEL=minimax/video-01
REPLICATE_MUSIC_MODEL=meta/musicgen
REPLICATE_VOICE_MODEL=lucataco/xtts-v2

# --- apps/api ---
# 4100/3100 (not the more common 4000/3000) to avoid colliding with other
# local dev tools already using the common defaults.
ADMIN_API_KEY=
PORT=4100
WEB_ORIGIN=http://localhost:3100
# https://sentry.io - optional. Without this set, apps/api and its worker
# process still log everything locally (see src/monitoring/alerting.ts),
# they just don't report errors anywhere durable/alertable.
SENTRY_DSN=

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:4100
NEXT_PUBLIC_APP_URL=http://localhost:3100

# --- Transactional email (apps/web/lib/email.ts) ---
# https://resend.com/api-keys - used for password-reset and email-verification
# links. Without this set, both flows still work end to end in local dev -
# the link is logged to the server console instead of actually emailed.
RESEND_API_KEY=
EMAIL_FROM="MoVAI <onboarding@resend.dev>"
