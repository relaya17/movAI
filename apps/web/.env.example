# Database
DATABASE_URL="postgresql://movai:movai@localhost:5433/movai"

# NextAuth
AUTH_SECRET="generate-a-random-32-char-secret-here"
AUTH_URL="http://localhost:3100"
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# OAuth Providers (optional). Names matter: Auth.js's zero-config Google/
# GitHub provider imports (see auth.ts) auto-read exactly these AUTH_*
# variable names - GITHUB_CLIENT_ID/GOOGLE_CLIENT_ID (this file's previous
# names) are silently ignored, which looks like "OAuth sign-in just doesn't
# work" with no error anywhere.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudinary (for uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# AI Studio generation (lib/replicate.ts) - Replicate hosts the actual
# video/music/voice models. Without this set, the Studio's generate buttons
# fail with a clear "AI generation is not configured" error.
REPLICATE_API_TOKEN=""

# Redis (used by lib/rate-limit.ts for login brute-force protection).
# Port 6380 matches docker-compose.yml - a bare REDIS_HOST/REDIS_PORT=6379
# pair here previously pointed at a port nothing is listening on locally.
REDIS_URL="redis://127.0.0.1:6380"

# TMDB (for movie metadata enrichment: posters, genres, ratings)
# Get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""

# Sentry (for error monitoring - optional, logs locally when not set)
# Get your DSN at https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=""


# Transactional email (lib/email.ts) - password reset + email verification links.
# https://resend.com/api-keys - without this set, both flows still work end
# to end in local dev, the link is just logged to the server console instead
# of actually emailed.
RESEND_API_KEY=""
EMAIL_FROM="MoVAI <onboarding@resend.dev>"

# Inbox for the /contact form (lib/contact-actions.ts) and the accessibility
# statement's contact line. Falls back to the first ADMIN_EMAILS entry if unset.
SUPPORT_EMAIL="support@relaya.com"

# Admin access (lib/admin.ts) - comma-separated allowlist of account emails
# that can reach /admin/sponsors (manual sponsor-banner management). No
# roles/permissions system exists yet - this is intentionally a simple
# env-var allowlist for a single-operator site, same pattern as apps/api's
# ADMIN_API_KEY.
ADMIN_EMAILS=""
